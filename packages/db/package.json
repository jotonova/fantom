{
  "name": "@fantom/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "tsc && drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed/novacor.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "dotenv": "^16.4.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/pg": "^8.11.0",
    "bcrypt": "^5.1.0",
    "drizzle-kit": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
