# Worker environment variables
# Copy to .env.local and fill in values for local development.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fantom-assets
R2_PUBLIC_URL=

# ── ElevenLabs (TTS / voice cloning) ─────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── AssemblyAI (video transcription) ─────────────────────────────────────────
# Required for video preprocessing. Get from https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# ── Runway (AI video generation) ─────────────────────────────────────────────
RUNWAY_API_KEY=
RUNWAY_MONTHLY_CAP_USD=100

# ── Alerts (optional — in-app only, Resend alerts disabled in worker) ─────────
RESEND_API_KEY=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# ── Health server ─────────────────────────────────────────────────────────────
PORT_HEALTH=9999
