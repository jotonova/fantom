# Web app environment variables (NEXT_PUBLIC_* vars are embedded at build time)
# Copy to .env.local and fill in values for local development.

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to 'true' to show legacy /library photo upload path in nav.
# Default false — photo path is shelved pending Module 1 v2 ship.
NEXT_PUBLIC_PHOTO_PATH_VISIBLE=false
