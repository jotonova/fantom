DATABASE_URL=postgres://fantom:password@localhost:5432/fantom
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development

# JWT — required in production. Generate with: openssl rand -base64 64
JWT_SECRET=dev-secret-change-in-production

# Owner-role connection string (used only by db:migrate / drizzle-kit).
# Before app_user is provisioned, leave this unset — DATABASE_URL is used as fallback.
# After migration 0003 and the DATABASE_URL switch, set this to the original owner URL
# so Render's pre-deploy migration step still has DDL privileges.
# MIGRATE_DATABASE_URL=postgres://owner:password@host/fantom

# Allowed CORS origins — comma-separated list of URLs (no trailing slashes).
# WEB_URLS takes precedence over WEB_URL if both are set.
WEB_URLS=http://localhost:3000,https://your-app.vercel.app

# Deprecated: use WEB_URLS instead. Still supported as a single-origin fallback.
# WEB_URL=http://localhost:3000

# ── Cloudflare R2 (F5) ───────────────────────────────────────────────────────
# R2 account ID — visible in the Cloudflare dashboard URL and on the R2 overview page.
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API token credentials — create via Cloudflare dashboard → R2 → Manage API Tokens.
# Grant: Object Read & Write on the fantom-assets bucket.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 bucket name (must exist — create via Cloudflare dashboard before deploying).
R2_BUCKET_NAME=fantom-assets

# Public URL for the bucket — the pub-xxxxx.r2.dev domain shown on the bucket's
# "Public access" tab after enabling it. No trailing slash.
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ── ElevenLabs (F5) ──────────────────────────────────────────────────────────
# ElevenLabs API key — available at elevenlabs.io → Profile → API Keys.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
